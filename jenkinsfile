pipeline {
    agent any

    stages {
        stage('Clone') {
            steps {
                git 'https://github.com/YOUR-USERNAME/devops-secure-pipeline.git'
            }
        }

        stage('Secret Scan') {
            steps {
                sh 'gitleaks detect --source . --exit-code 1'
            }
        }

        stage('Build') {
            steps {
                sh 'docker build -t myapp .'
            }
        }

        stage('Scan') {
            steps {
                sh 'trivy image --exit-code 1 --severity HIGH,CRITICAL myapp'
            }
        }

        stage('Run') {
            steps {
                sh 'docker run -d -p 5000:5000 myapp'
            }
        }
    }
}
